  <owl:Ontology rdf:about="http://www.w3id.org/dpp_environmentalImpact">
    <owl:versionIRI rdf:resource="http://www.w3id.org/dpp/environmental/1.0"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title>Digital Product Passport – Environmental Impact Module Ontology</dcterms:title>
    <dcterms:creator>Rahel Kebede</dcterms:creator>
    <dcterms:contributor>Peter Johansson</dcterms:contributor>
    <dcterms:contributor>Annika Moscati</dcterms:contributor>
    <dcterms:description>This ontology defines concepts and properties related to the environmental impacts of products within a Digital Product Passport (DPP), including lifecycle assessment indicators, emissions, and sustainability metrics.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-10-29</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>
