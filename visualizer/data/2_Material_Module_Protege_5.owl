  <owl:Ontology rdf:about="http://www.w3id.org/dpp_material">
    <owl:versionIRI rdf:resource="http://www.w3id.org/dpp/dpp_material/1.0"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title>Digital Product Passport – Material Module Ontology</dcterms:title>
    <dcterms:creator>Rahel Kebede</dcterms:creator>
    <dcterms:contributor>Peter Johansson</dcterms:contributor>
    <dcterms:contributor>Annika Moscati</dcterms:contributor>
    <dcterms:description>This ontology defines key material-related concepts and properties for the Material Module of a Digital Product Passport (DPP), supporting the semantic representation of material specifications, classifications, and sustainability indicators.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-10-28</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>
