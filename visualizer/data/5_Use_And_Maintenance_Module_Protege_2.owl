  <owl:Ontology rdf:about="http://www.w3id.org/dpp/UseAndMaintenance">
    <owl:versionIRI rdf:resource="http://www.w3id.org/dpp/use-maintenance/1.0"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title>Digital Product Passport – Use and Maintenance Module Ontology</dcterms:title>
    <dcterms:creator>Rahel Kebede</dcterms:creator>
    <dcterms:contributor>Peter Johansson</dcterms:contributor>
    <dcterms:contributor>Annika Moscati</dcterms:contributor>
    <dcterms:description>This ontology defines concepts and properties related to the use phase and maintenance of products within a Digital Product Passport (DPP), covering usage instructions, maintenance schedules, and operational performance data.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-10</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>
