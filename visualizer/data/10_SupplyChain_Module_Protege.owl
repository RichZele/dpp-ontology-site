  <owl:Ontology rdf:about="http://www.w3id.org/dpp/SupplyChain">
    <owl:versionIRI rdf:resource="http://www.w3id.org/dpp/SupplyChain/1.0"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title>Digital Product Passport – Supply Chain Module Ontology</dcterms:title>
    <dcterms:creator>Rahel Kebede</dcterms:creator>
    <dcterms:contributor>Peter Johansson</dcterms:contributor>
    <dcterms:contributor>Annika Moscati</dcterms:contributor>
    <dcterms:description>This ontology defines concepts and properties related to the supply chain of products in a Digital Product Passport (DPP), including suppliers, logistics, traceability, and related documentation.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-13</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>
