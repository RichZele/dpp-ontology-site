      <owl:ObjectProperty rdf:about="http://www.w3id.org/dpp/SupplyChain#manages">
        <rdfs:domain rdf:resource="http://www.w3id.org/dpp#SupplyChainManagement"/>
        <rdfs:range rdf:resource="http://www.w3id.org/dpp/SupplyChain#PhysicalEntity"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp/SupplyChain#PhysicalEntity"/>
    <rdfs:range rdf:resource="http://www.w3id.org/dpp#SupplyChainManagement"/>
  </owl:ObjectProperty>
