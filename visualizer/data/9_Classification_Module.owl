<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:ObjectProperty rdf:about="http://www.w3id.org/dpp#hasClassification">
    <rdfs:label xml:lang="en">has classification</rdfs:label>
    <rdfs:comment xml:lang="en">Links a product, material, or component to its classification</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Component"/>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Material"/>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Product"/>
    <rdfs:range rdf:resource="http://www.w3id.org/dpp#Classification"/>
  </owl:ObjectProperty>
  <owl:Ontology rdf:about="http://www.w3id.org/dpp/classification">
    <owl:versionIRI rdf:resource="http://www.w3id.org/dpp/classification/1.0"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title>Digital Product Passport – Classification Module Ontology</dcterms:title>
    <dcterms:creator>Rahel Kebede</dcterms:creator>
    <dcterms:contributor>Peter Johansson</dcterms:contributor>
    <dcterms:contributor>Annika Moscati</dcterms:contributor>
    <dcterms:description>This ontology defines concepts and properties for classifying products within a Digital Product Passport (DPP), supporting multiple classification systems and hierarchies such as functional or material-based classification.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-09-08</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>
  <owl:DatatypeProperty rdf:about="http://www.w3id.org/dpp#classificationName">
    <rdfs:label xml:lang="en">classification name</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the classification</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Classification"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://www.w3id.org/dpp#classifiesComponent">
    <rdfs:label xml:lang="en">classifies component</rdfs:label>
    <rdfs:comment xml:lang="en">Links the classification to the components it classifies</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Classification"/>
    <rdfs:range rdf:resource="http://www.w3id.org/dpp#Component"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.w3id.org/dpp#classifiesProduct">
    <rdfs:label xml:lang="en">classifies products</rdfs:label>
    <rdfs:comment xml:lang="en">Links the classification to the products it classifies</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Classification"/>
    <rdfs:range rdf:resource="http://www.w3id.org/dpp#Product"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://www.w3id.org/dpp#classificationCode">
    <rdfs:label xml:lang="en">classification code</rdfs:label>
    <rdfs:comment xml:lang="en">A unique code or identifier for the classification</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Classification"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.w3id.org/dpp#classificationDescription">
    <rdfs:label xml:lang="en">classification description</rdfs:label>
    <rdfs:comment xml:lang="en">A description of the classification</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Classification"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://www.w3id.org/dpp#classifiesMaterial">
    <rdfs:label xml:lang="en">classifies material</rdfs:label>
    <rdfs:comment xml:lang="en">Links the classification to the materials it classifies</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3id.org/dpp#Classification"/>
    <rdfs:range rdf:resource="http://www.w3id.org/dpp#Material"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="http://www.w3id.org/dpp#Classification">
    <rdfs:label xml:lang="en">Classification</rdfs:label>
    <rdfs:comment xml:lang="en">A hierarchical or categorical system used for organizing and classifying information about products, components, or other items based on their shared characteristics, properties, or features.</rdfs:comment>
  </owl:Class>
</rdf:RDF>
