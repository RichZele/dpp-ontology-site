  <owl:Ontology rdf:about="http://www.w3id.org/dpp">
    <owl:versionIRI rdf:resource="http://www.w3id.org/dpp/product/1.0"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title>Digital Product Passport – Product Module Ontology</dcterms:title>
    <dcterms:creator>Rahel Kebede</dcterms:creator>
    <dcterms:contributor>Peter Johansson</dcterms:contributor>
    <dcterms:contributor>Annika Moscati</dcterms:contributor>
    <dcterms:description>This ontology defines the core product-related concepts and properties used in the Product Module of a Digital Product Passport (DPP), focusing on the description, classification, and technical characteristics of products.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-05</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>
