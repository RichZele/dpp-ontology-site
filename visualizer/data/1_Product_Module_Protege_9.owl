  <owl:Class rdf:about="http://www.w3id.org/dpp#ManufacturingRole">
    <rdfs:subClassOf rdf:resource="http://www.w3id.org/dpp#AgentRole"/>
    <ns2:entityPosition>
      <rdf:Description rdf:nodeID="nb5f1ca74a4ba49d98fa1ca9923ffec65b44">
        <ns2:entityPositionX rdf:datatype="http://www.w3.org/2001/XMLSchema#double">590.2321710146668</ns2:entityPositionX>
        <ns2:entityPositionY rdf:datatype="http://www.w3.org/2001/XMLSchema#double">929.7376480679713</ns2:entityPositionY>
        <rdfs:comment xml:lang="en">This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view.</rdfs:comment>
      </rdf:Description>
    </ns2:entityPosition>
    <rdfs:comment xml:lang="en">A specialized role denoting the responsibility or action of producing goods in large quantities, typically by machinery. This role is primarily associated with manufacturers who engage in the production of products or components. The manufacturing role encompasses various processes including assembly, quality control, and packaging, ensuring that products are produced according to specified standards and specifications.</rdfs:comment>
    <rdfs:label>ManufacturingRole</rdfs:label>
  </owl:Class>
