<?xml version="1.0"?>
<rdf:RDF xmlns="http://w3id.org/dpp/data-categories#"
     xml:base="http://w3id.org/dpp/data-categories"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:access-control="http://w3id.org/dpp/access-control#"
     xmlns:data-categories="http://w3id.org/dpp/data-categories#">
    <owl:Ontology rdf:about="http://w3id.org/dpp/data-categories">
        <owl:versionIRI rdf:resource="http://w3id.org/dpp/data-categories/1.0.0"/>
        <owl:imports rdf:resource="http://w3id.org/dpp/access-control"/>
        <terms:contributor>Annika Moscati</terms:contributor>
        <terms:contributor>Bincy Veena</terms:contributor>
        <terms:contributor>Peter Johansson</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-01</terms:created>
        <terms:creator>Rahel Kebede</terms:creator>
        <terms:description xml:lang="en">ESPR Annex III-aligned taxonomy of Digital Product Passport data categories.
         Used as the canonical resource classification for dpp-ac access control
         policy scoping. Data categories are modelled as OWL classes (not individuals)
         to enable subsumption-based policy inheritance.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">DPP Data Category Taxonomy</terms:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
