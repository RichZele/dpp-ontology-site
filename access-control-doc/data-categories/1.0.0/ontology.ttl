@base <http://w3id.org/dpp/data-categories#> .

<http://w3id.org/dpp/data-categories> rdf:type owl:Ontology ;
                                       owl:versionIRI <http://w3id.org/dpp/data-categories/1.0.0> ;
                                       owl:imports <http://w3id.org/dpp/access-control> ;
                                       <http://purl.org/dc/terms/contributor> "Annika Moscati" ,
                                                                              "Bincy Veena" ,
                                                                              "Peter Johansson" ;
                                       <http://purl.org/dc/terms/created> "2026-04-01"^^xsd:date ;
                                       <http://purl.org/dc/terms/creator> "Rahel Kebede" ;
                                       <http://purl.org/dc/terms/description> """ESPR Annex III-aligned taxonomy of Digital Product Passport data categories.
         Used as the canonical resource classification for dpp-ac access control
         policy scoping. Data categories are modelled as OWL classes (not individuals)
         to enable subsumption-based policy inheritance."""@en ;
                                       <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                       <http://purl.org/dc/terms/title> "DPP Data Category Taxonomy"@en ;
                                       owl:versionInfo "1.0.0" .

