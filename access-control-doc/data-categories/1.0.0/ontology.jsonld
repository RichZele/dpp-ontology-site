  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A distinct stage in the product lifecycle during which\n         specific DPP data categories may be created or accessed."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Product Lifecycle Phase"
  } ]
}, {
