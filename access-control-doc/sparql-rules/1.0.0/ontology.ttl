# ============================================================
# ONTOLOGY DECLARATION — SPARQL-BASED RULES MODULE
# ============================================================

<http://w3id.org/dpp/access-control/sparql-rules>
    rdf:type owl:Ontology ;
    owl:versionIRI <http://w3id.org/dpp/access-control/sparql-rules/1.0.0> ;
    owl:imports <http://w3id.org/dpp/access-control> ;
    dcterms:title "DPP Access Control — SPARQL Rule Set"@en ;
    dcterms:description
        """SPARQL CONSTRUCT rules implementing access decision logic for the
         dpp-ac framework. Rule selection rationale documented in
         docs/decisions/ADR-001-rule-mechanism.md."""@en ;
