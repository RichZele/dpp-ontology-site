<?xml version="1.0"?>
<rdf:RDF xmlns="http://w3id.org/dpp/roles#"
     xml:base="http://w3id.org/dpp/roles"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://w3id.org/dpp/roles">
        <owl:versionIRI rdf:resource="http://w3id.org/dpp/roles/1.0.0"/>
        <owl:imports rdf:resource="http://w3id.org/dpp/access-control"/>
        <terms:contributor>Annika Moscati</terms:contributor>
        <terms:contributor>Bincy Veena</terms:contributor>
        <terms:contributor>Peter Johansson</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-01</terms:created>
        <terms:creator>Rahel Kebede</terms:creator>
        <terms:description xml:lang="en">OWL class hierarchy of stakeholder roles defined in the ESPR Digital
         Product Passport framework. Roles are modelled as classes (not individuals)
         to support ABAC attribute constraints via class-level SHACL shapes.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">DPP Stakeholder Role Taxonomy</terms:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


