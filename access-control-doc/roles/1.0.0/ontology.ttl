@prefix : <http://w3id.org/dpp/roles#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://w3id.org/dpp/roles#> .

<http://w3id.org/dpp/roles> rdf:type owl:Ontology ;
                             owl:versionIRI <http://w3id.org/dpp/roles/1.0.0> ;
                             owl:imports <http://w3id.org/dpp/access-control> ;
                             <http://purl.org/dc/terms/contributor> "Annika Moscati" ,
                                                                    "Bincy Veena" ,
                                                                    "Peter Johansson" ;
                             <http://purl.org/dc/terms/created> "2026-04-01"^^xsd:date ;
                             <http://purl.org/dc/terms/creator> "Rahel Kebede" ;
                             <http://purl.org/dc/terms/description> """OWL class hierarchy of stakeholder roles defined in the ESPR Digital
         Product Passport framework. Roles are modelled as classes (not individuals)
         to support ABAC attribute constraints via class-level SHACL shapes."""@en ;
                             <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                             <http://purl.org/dc/terms/title> "DPP Stakeholder Role Taxonomy"@en ;
                             owl:versionInfo "1.0.0" .

