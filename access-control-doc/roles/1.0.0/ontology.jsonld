[ {
  "@id" : "http://purl.org/dc/terms/contributor",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/created",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/creator",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/description",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/license",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/title",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#Role",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://w3id.org/dpp/roles",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Annika Moscati"
  }, {
    "@value" : "Bincy Veena"
  }, {
    "@value" : "Peter Johansson"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-01"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Rahel Kebede"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "OWL class hierarchy of stakeholder roles defined in the ESPR Digital\n         Product Passport framework. Roles are modelled as classes (not individuals)\n         to support ABAC attribute constraints via class-level SHACL shapes."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "DPP Stakeholder Role Taxonomy"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://w3id.org/dpp/access-control"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http://w3id.org/dpp/roles/1.0.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0.0"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#AuthorisedRepresentativeRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#EconomicOperator"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A natural or legal person established in the EU mandated by\n         the manufacturer to act on their behalf."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Authorised Representative"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "ESPR Article 4(1)(d)."
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#ConsumerRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/access-control#Role"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An end user with read access to public and use-phase DPP data,\n         including product identification and energy efficiency data."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Consumer"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#CustomsAuthorityRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#RegulatoryAuthority"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A customs enforcement authority with read access to\n         product identification and certification data at border control."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Customs Authority"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#DistributorRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#EconomicOperator"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An entity in the supply chain that makes a product available\n         on the market other than the manufacturer or importer."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Distributor"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "ESPR Article 4(1)(c)."
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#EconomicOperator",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/access-control#Role"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A role defined under ESPR Article 4 with specific DPP data\n         rights and obligations."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Economic Operator"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#ImporterRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#EconomicOperator"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An entity that places products manufactured outside the EU\n         on the EU market and assumes ESPR obligations."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Importer"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "ESPR Article 4(1)(b)."
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#MaintenanceTechnicianRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#ServiceProviderRole"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A certified technician performing repair or maintenance with\n         read access to use-and-maintenance and repairability data."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Maintenance Technician"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#ManufacturerRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#EconomicOperator"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The entity that manufactures the product and is the primary\n         DPP data owner with full read/write access to all modules."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Manufacturer"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "ESPR Article 4(1)(a)."
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#MarketSurveillanceAuthorityRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/roles#RegulatoryAuthority"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A national authority with full read access to all DPP\n         modules per ESPR Article 14."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Market Surveillance Authority"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "ESPR Article 14; Regulation (EU) 2019/1020."
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#RecyclerRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/access-control#Role"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An entity processing products at end-of-life with read access\n         to material composition and disassembly instruction data."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Recycler"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#RegulatoryAuthority",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/access-control#Role"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A public authority with statutory rights to access DPP data\n         for market surveillance or customs enforcement."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Regulatory Authority"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/roles#ServiceProviderRole",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://w3id.org/dpp/access-control#Role"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An entity providing after-sales services such as repair,\n         maintenance, or refurbishment."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Service Provider"
  } ]
}, {
  "@id" : "http://www.w3.org/2001/XMLSchema#date",
  "@type" : [ "http://www.w3.org/2000/01/rdf-schema#Datatype" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#definition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#prefLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#scopeNote",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
} ]