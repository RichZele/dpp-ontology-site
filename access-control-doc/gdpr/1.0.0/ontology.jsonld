[ {
  "@id" : "http://purl.org/dc/terms/contributor",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/created",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/creator",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/description",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/license",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/title",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#AccessPolicy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#ConsentBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#LegalBasis"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The data subject has given consent to the processing of their personal\n         data for one or more specific purposes."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Consent (Art. 6(1)(a))"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#DataRetentionPolicy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/dpv#Policy"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A time-bound policy governing how long a DPP data category may be\n         retained before erasure or anonymisation."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Data Retention Policy"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#DataSubjectRight",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/dpv#Right"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A GDPR Chapter III right held by a natural person whose personal data\n         is processed in the context of DPP operations."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Data Subject Right"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#LegalBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/dpv#LegalBasis"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The GDPR Article 6 legal basis justifying the processing of personal\n         data in the context of a DPP access operation."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "DPP Legal Basis"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#LegalObligation",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#LegalBasis"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Processing is necessary for compliance with a legal obligation to which\n         the controller is subject — including ESPR data disclosure obligations."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Legal Obligation (Art. 6(1)(c))"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#LegitimateInterest",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#LegalBasis"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Processing is necessary for the purposes of the legitimate interests\n         pursued by the controller or a third party."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Legitimate Interest (Art. 6(1)(f))"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#PublicTaskBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#LegalBasis"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Processing is necessary for the performance of a task carried out in\n         the public interest or in the exercise of official authority — relevant\n         for Market Surveillance Authority access."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Public Task (Art. 6(1)(e))"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#RightOfAccess",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataSubjectRight"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The right to obtain confirmation of whether personal data is being\n         processed and to access that data."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Right of Access (Art. 15)"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#RightToDataPortability",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataSubjectRight"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The right to receive personal data in a structured, commonly used,\n         and machine-readable format."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Right to Data Portability (Art. 20)"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#RightToErasure",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataSubjectRight"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The right to have personal data erased where it is no longer\n         necessary for the purpose for which it was collected."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Right to Erasure (Art. 17)"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#RightToRectification",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataSubjectRight"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The right to have inaccurate personal data corrected without undue delay."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Right to Rectification (Art. 16)"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#hasLegalBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://w3id.org/dpp/access-control#AccessPolicy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://w3id.org/dpp/access-control#LegalBasis"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The GDPR Article 6 legal basis that justifies issuing this policy."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "has legal basis"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#hasRetentionPolicy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://w3id.org/dpp/data-categories#DataCategory"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataRetentionPolicy"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Links a DPP data category to its applicable data retention policy."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "has retention policy"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control#retentionPeriodYears",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataRetentionPolicy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#integer"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The number of years for which data in this category must be retained\n         before erasure or anonymisation is triggered."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "retention period (years)"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control/gdpr",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Annika Moscati"
  }, {
    "@value" : "Bincy Veena"
  }, {
    "@value" : "Peter Johansson"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-01"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Rahel Kebede"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Legal basis declarations, purpose limitation patterns, data subject rights,\n         and data retention policies connecting the dpp-ac framework to GDPR via the\n         Data Privacy Vocabulary (DPVO)."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "DPP Access Control — GDPR Regulatory Alignment"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://w3id.org/dpp/access-control"
  }, {
    "@id" : "https://w3id.org/dpv#"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http://w3id.org/dpp/access-control/gdpr/1.0.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0.0"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control/gdpr/RetentionPolicy-ProductId",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://w3id.org/dpp/access-control#retentionPeriodYears" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "15"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataRetentionPolicy"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Product Identification Data Retention — 15 years"
  } ]
}, {
  "@id" : "http://w3id.org/dpp/access-control/gdpr/RetentionPolicy-SupplyChain",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://w3id.org/dpp/access-control#retentionPeriodYears" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "10"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://w3id.org/dpp/access-control#DataRetentionPolicy"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Supply Chain Data Retention — 10 years"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "ESPR supply chain data must be retained for the product's\n         service life plus 10 years per proposed delegated acts."
  } ]
}, {
  "@id" : "http://w3id.org/dpp/data-categories#DataCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://www.w3.org/2001/XMLSchema#date",
  "@type" : [ "http://www.w3.org/2000/01/rdf-schema#Datatype" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#definition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#prefLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#scopeNote",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/dpv#LegalBasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "https://w3id.org/dpv#Policy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "https://w3id.org/dpv#Right",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
} ]