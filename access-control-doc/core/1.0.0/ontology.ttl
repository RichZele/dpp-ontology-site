@prefix : <http://w3id.org/dpp/access-control#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://w3id.org/dpp/access-control#> .

<http://w3id.org/dpp/access-control> rdf:type owl:Ontology ;
                                      owl:versionIRI <http://w3id.org/dpp/access-control/1.0.0> ;
                                      owl:imports <http://www.w3.org/ns/prov#> ;
                                      <http://purl.org/dc/terms/contributor> "Annika Moscati" ,
                                                                             "Bincy Veena" ,
                                                                             "Peter Johansson" ;
                                      <http://purl.org/dc/terms/created> "2026-04-01"^^xsd:date ;
                                      <http://purl.org/dc/terms/creator> "Rahel Kebede" ;
                                      <http://purl.org/dc/terms/description> """A modular semantic framework for role-, attribute-, relationship-, and
         purpose-based access control over Digital Product Passport data,
         aligned with ESPR, GDPR, and ODRL 2.2."""@en ;
                                      <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                      <http://purl.org/dc/terms/title> "DPP Access Control Ontology Module"@en ;
                                      owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
<http://www.w3.org/2004/02/skos/core#scopeNote> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://w3id.org/dpp/access-control#appliedPolicy
:appliedPolicy rdf:type owl:ObjectProperty ;
               rdfs:domain :AccessDecision ;
               rdfs:range :AccessPolicy ;
               <http://www.w3.org/2004/02/skos/core#definition> """The AccessPolicy (or policies) that were evaluated to produce
         this decision."""@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "applied policy"@en .


###  http://w3id.org/dpp/access-control#appliesToRole
:appliesToRole rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :AccessPolicy ;
               rdfs:range :Role ;
               <http://www.w3.org/2004/02/skos/core#definition> "The Role to which this AccessPolicy is addressed."@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "applies to role"@en .


###  http://w3id.org/dpp/access-control#belongsToModule
:belongsToModule rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :DPPResource ;
                 rdfs:range <http://w3id.org/dpp/data-categories#DataCategory> ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The ESPR-defined data category (DPP module) that contains this resource."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "belongs to module"@en .


###  http://w3id.org/dpp/access-control#decidesOn
:decidesOn rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :AccessDecision ;
           rdfs:range :AccessRequest ;
           <http://www.w3.org/2004/02/skos/core#definition> "Links this AccessDecision to the AccessRequest it resolves."@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "decides on"@en .


###  http://w3id.org/dpp/access-control#delegatedBy
:delegatedBy rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Delegation ;
             rdfs:range :Principal ;
             <http://www.w3.org/2004/02/skos/core#definition> "The Principal who grants delegated access rights."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "delegated by"@en .


###  http://w3id.org/dpp/access-control#delegatedTo
:delegatedTo rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Delegation ;
             rdfs:range :Principal ;
             <http://www.w3.org/2004/02/skos/core#definition> "The Principal who receives delegated access rights."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "delegated to"@en .


###  http://w3id.org/dpp/access-control#delegationCoversAction
:delegationCoversAction rdf:type owl:ObjectProperty ;
                        rdfs:domain :Delegation ;
                        rdfs:range <http://www.w3.org/ns/odrl/2/Action> ;
                        <http://www.w3.org/2004/02/skos/core#definition> "The action(s) the delegatee is authorised to perform."@en ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "delegation covers action"@en .


###  http://w3id.org/dpp/access-control#delegationCoversResource
:delegationCoversResource rdf:type owl:ObjectProperty ;
                          rdfs:domain :Delegation ;
                          rdfs:range :DPPResource ;
                          <http://www.w3.org/2004/02/skos/core#definition> "The DPP resource(s) over which delegated rights are granted."@en ;
                          <http://www.w3.org/2004/02/skos/core#prefLabel> "delegation covers resource"@en .


###  http://w3id.org/dpp/access-control#hasAttributeConstraint
:hasAttributeConstraint rdf:type owl:ObjectProperty ;
                        rdfs:domain :AccessPolicy ;
                        rdfs:range :AttributeConstraint ;
                        <http://www.w3.org/2004/02/skos/core#definition> """Links an AccessPolicy to one or more AttributeConstraints that
         must all be satisfied for the policy's permissions to activate."""@en ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "has attribute constraint"@en .


###  http://w3id.org/dpp/access-control#hasRole
:hasRole rdf:type owl:ObjectProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Principal ;
         rdfs:range :Role ;
         <http://www.w3.org/2004/02/skos/core#definition> "Assigns a single Access Control Role to a Principal."@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "has role"@en .


###  http://w3id.org/dpp/access-control#ownedBy
:ownedBy rdf:type owl:ObjectProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :DPPResource ;
         rdfs:range :Principal ;
         <http://www.w3.org/2004/02/skos/core#definition> """The Principal who is the authoritative data owner of this
         DPP resource and may grant or revoke access."""@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "owned by"@en .


###  http://w3id.org/dpp/access-control#policyOwner
:policyOwner rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :AccessPolicy ;
             rdfs:range :Principal ;
             <http://www.w3.org/2004/02/skos/core#definition> "The Principal responsible for the lifecycle of this policy."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "policy owner"@en .


###  http://w3id.org/dpp/access-control#requestContext
:requestContext rdf:type owl:ObjectProperty ;
                rdfs:domain :AccessRequest ;
                rdfs:range :AccessContext ;
                <http://www.w3.org/2004/02/skos/core#definition> """Environmental or situational metadata that conditions the evaluation
         of this access request."""@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "request context"@en .


###  http://w3id.org/dpp/access-control#requestedAction
:requestedAction rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :AccessRequest ;
                 rdfs:range <http://www.w3.org/ns/odrl/2/Action> ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The CRUD action the Principal intends to perform."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "requested action"@en .


###  http://w3id.org/dpp/access-control#requestedBy
:requestedBy rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :AccessRequest ;
             rdfs:range :Principal ;
             <http://www.w3.org/2004/02/skos/core#definition> "Links an AccessRequest to the Principal who submitted it."@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "requested by"@en .


###  http://w3id.org/dpp/access-control#requestedResource
:requestedResource rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :AccessRequest ;
                   rdfs:range :DPPResource ;
                   <http://www.w3.org/2004/02/skos/core#definition> "The DPP resource the Principal intends to access."@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "requested resource"@en .


#################################################################
#    Data properties
#################################################################

###  http://w3id.org/dpp/access-control#accessValidFrom
:accessValidFrom rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :TemporalContext ;
                 rdfs:range xsd:dateTime ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time from which this temporal access window opens."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "access valid from"@en .


###  http://w3id.org/dpp/access-control#accessValidUntil
:accessValidUntil rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :TemporalContext ;
                  rdfs:range xsd:dateTime ;
                  <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time at which this temporal access window closes."@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "access valid until"@en .


###  http://w3id.org/dpp/access-control#certificationIsValid
:certificationIsValid rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain :CertificationContext ;
                      rdfs:range xsd:boolean ;
                      <http://www.w3.org/2004/02/skos/core#definition> "True if the referenced certification is currently valid and in good standing."@en ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "certification is valid"@en .


###  http://w3id.org/dpp/access-control#certificationScheme
:certificationScheme rdf:type owl:DatatypeProperty ;
                     rdfs:domain :CertificationContext ;
                     rdfs:range xsd:string ;
                     <http://www.w3.org/2004/02/skos/core#definition> "The name or identifier of the certification scheme."@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "certification scheme"@en .


###  http://w3id.org/dpp/access-control#conflictResolutionApplied
:conflictResolutionApplied rdf:type owl:DatatypeProperty ;
                           rdfs:domain :AccessDecision ;
                           rdfs:range xsd:boolean ;
                           <http://www.w3.org/2004/02/skos/core#definition> """True if a deny-overrides conflict resolution strategy was
         invoked during this decision evaluation."""@en ;
                           <http://www.w3.org/2004/02/skos/core#prefLabel> "conflict resolution applied"@en .


###  http://w3id.org/dpp/access-control#constraintAttribute
:constraintAttribute rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :AttributeConstraint ;
                     rdfs:range xsd:string ;
                     <http://www.w3.org/2004/02/skos/core#definition> "The name of the attribute being constrained."@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "constraint attribute"@en ;
                     <http://www.w3.org/2004/02/skos/core#scopeNote> "E.g., trustAssuranceLevel, resourceSensitivity, certificationIsValid."@en .


###  http://w3id.org/dpp/access-control#constraintOperator
:constraintOperator rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :AttributeConstraint ;
                    rdfs:range xsd:string ;
                    <http://www.w3.org/2004/02/skos/core#definition> "The comparison operator applied to the attribute value."@en ;
                    <http://www.w3.org/2004/02/skos/core#prefLabel> "constraint operator"@en ;
                    <http://www.w3.org/2004/02/skos/core#scopeNote> "Allowed values: EQ, NEQ, GT, LT, GTE, LTE, IN."@en .


###  http://w3id.org/dpp/access-control#constraintValue
:constraintValue rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :AttributeConstraint ;
                 rdfs:range xsd:string ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The value against which the attribute is compared."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "constraint value"@en .


###  http://w3id.org/dpp/access-control#decisionOutcome
:decisionOutcome rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :AccessDecision ;
                 rdfs:range xsd:string ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The result of evaluating the access request."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "decision outcome"@en ;
                 <http://www.w3.org/2004/02/skos/core#scopeNote> "Allowed values: GRANT, DENY, DELEGATE, PENDING."@en .


###  http://w3id.org/dpp/access-control#decisionTimestamp
:decisionTimestamp rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :AccessDecision ;
                   rdfs:range xsd:dateTime ;
                   <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time at which the access decision was recorded."@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "decision timestamp"@en .


###  http://w3id.org/dpp/access-control#declaredPurpose
:declaredPurpose rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :PurposeContext ;
                 rdfs:range xsd:string ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A textual description of the purpose for which data access is requested."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "declared purpose"@en .


###  http://w3id.org/dpp/access-control#delegationDepth
:delegationDepth rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Delegation ;
                 rdfs:range xsd:integer ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The number of sub-delegation hops permitted from this delegation."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "delegation depth"@en ;
                 <http://www.w3.org/2004/02/skos/core#scopeNote> "Maximum allowed value is 1. Sub-delegation is prohibited by policy."@en .


###  http://w3id.org/dpp/access-control#delegationIsActive
:delegationIsActive rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Delegation ;
                    rdfs:range xsd:boolean ;
                    <http://www.w3.org/2004/02/skos/core#definition> """True if this delegation is currently within its valid time window
         and has not been revoked."""@en ;
                    <http://www.w3.org/2004/02/skos/core#prefLabel> "delegation is active"@en .


###  http://w3id.org/dpp/access-control#delegationValidFrom
:delegationValidFrom rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Delegation ;
                     rdfs:range xsd:dateTime ;
                     <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time from which the delegation is active."@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "delegation valid from"@en .


###  http://w3id.org/dpp/access-control#delegationValidUntil
:delegationValidUntil rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain :Delegation ;
                      rdfs:range xsd:dateTime ;
                      <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time at which the delegation expires."@en ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "delegation valid until"@en .


###  http://w3id.org/dpp/access-control#jurisdictionCode
:jurisdictionCode rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :GeographicContext ;
                  rdfs:range xsd:string ;
                  <http://www.w3.org/2004/02/skos/core#definition> "The jurisdiction in which this access constraint applies."@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "jurisdiction code"@en ;
                  <http://www.w3.org/2004/02/skos/core#scopeNote> "ISO 3166-1 alpha-2 country code, or the literals EU or EEA."@en .


###  http://w3id.org/dpp/access-control#permittedPurpose
:permittedPurpose rdf:type owl:DatatypeProperty ;
                  rdfs:domain :AccessPolicy ;
                  rdfs:range xsd:string ;
                  <http://www.w3.org/2004/02/skos/core#definition> """A purpose code that an access request must declare to activate
         this policy's permissions."""@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "permitted purpose"@en ;
                  <http://www.w3.org/2004/02/skos/core#scopeNote> """Must be one of the purpose codes defined in PurposeContextShape:
         MAINTENANCE, COMPLIANCE_AUDIT, RECYCLING_PROCESSING,
         MARKET_SURVEILLANCE, CUSTOMS_INSPECTION, CONSUMER_INFORMATION,
         RESEARCH_DEVELOPMENT, SUPPLY_CHAIN_DUE_DILIGENCE."""@en .


###  http://w3id.org/dpp/access-control#policyValidFrom
:policyValidFrom rdf:type owl:DatatypeProperty ;
                 rdfs:domain :AccessPolicy ;
                 rdfs:range xsd:dateTime ;
                 <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time from which this policy is active."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "policy valid from"@en .


###  http://w3id.org/dpp/access-control#policyValidUntil
:policyValidUntil rdf:type owl:DatatypeProperty ;
                  rdfs:domain :AccessPolicy ;
                  rdfs:range xsd:dateTime ;
                  <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time after which this policy expires."@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "policy valid until"@en .


###  http://w3id.org/dpp/access-control#requestTimestamp
:requestTimestamp rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :AccessRequest ;
                  rdfs:range xsd:dateTime ;
                  <http://www.w3.org/2004/02/skos/core#definition> "The UTC date-time at which the AccessRequest was submitted."@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "request timestamp"@en .


###  http://w3id.org/dpp/access-control#resourceSensitivity
:resourceSensitivity rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :DPPResource ;
                     rdfs:range xsd:string ;
                     <http://www.w3.org/2004/02/skos/core#definition> "Classification of the sensitivity level of this DPP resource."@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "resource sensitivity"@en ;
                     <http://www.w3.org/2004/02/skos/core#scopeNote> """Allowed values: PUBLIC, RESTRICTED, CONFIDENTIAL,
         STRICTLY_CONFIDENTIAL."""@en .


###  http://w3id.org/dpp/access-control#trustAssuranceLevel
:trustAssuranceLevel rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :TrustContext ;
                     rdfs:range xsd:string ;
                     <http://www.w3.org/2004/02/skos/core#definition> "The eIDAS assurance level of the requester's authentication."@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "trust assurance level"@en ;
                     <http://www.w3.org/2004/02/skos/core#scopeNote> "eIDAS values: LOW, SUBSTANTIAL, HIGH."@en .


#################################################################
#    Classes
#################################################################

###  http://w3id.org/dpp/access-control#AccessContext
:AccessContext rdf:type owl:Class ;
               <http://www.w3.org/2004/02/skos/core#definition> """Environmental, temporal, geographic, or purpose-related
         metadata that conditions the evaluation of an access
         request."""@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Access Context"@en .


###  http://w3id.org/dpp/access-control#AccessDecision
:AccessDecision rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                <http://www.w3.org/2004/02/skos/core#definition> """An immutable, time-stamped record of the outcome of evaluating
         an AccessRequest against applicable AccessPolicies."""@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "Access Decision"@en .


###  http://w3id.org/dpp/access-control#AccessPolicy
:AccessPolicy rdf:type owl:Class ;
              rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Policy> ;
              <http://www.w3.org/2004/02/skos/core#definition> """A declarative specification of permissions and prohibitions
         over DPP resources, scoped to a Role and optionally
         conditioned on contextual constraints."""@en ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "DPP Access Policy"@en .


###  http://w3id.org/dpp/access-control#AccessRequest
:AccessRequest rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
               <http://www.w3.org/2004/02/skos/core#definition> """A formal, time-stamped expression of intent by a Principal
         to perform a specific Action on a specific DPP resource."""@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Access Request"@en .


###  http://w3id.org/dpp/access-control#AttributeConstraint
:AttributeConstraint rdf:type owl:Class ;
                     <http://www.w3.org/2004/02/skos/core#definition> """A condition on a named attribute of the requesting Principal
         or target resource that must be satisfied for a policy's
         permissions to apply."""@en ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "Attribute Constraint"@en .


###  http://w3id.org/dpp/access-control#CertificationContext
:CertificationContext rdf:type owl:Class ;
                      rdfs:subClassOf :AccessContext ;
                      <http://www.w3.org/2004/02/skos/core#definition> """Evidence of a certification held by the requesting Principal
         that may unlock access to restricted DPP data."""@en ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Certification Context"@en .


###  http://w3id.org/dpp/access-control#DPPResource
:DPPResource rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Asset> ,
                             <http://www.w3.org/ns/prov#Entity> ;
             <http://www.w3.org/2004/02/skos/core#definition> """A discrete, addressable unit of data within a Digital Product
         Passport that may be the target of an access request."""@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "DPP Resource"@en .


###  http://w3id.org/dpp/access-control#Delegation
:Delegation rdf:type owl:Class ;
            rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
            <http://www.w3.org/2004/02/skos/core#definition> """A bounded, time-limited transfer of a subset of access rights
         from one Principal to another."""@en ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Delegation"@en .


###  http://w3id.org/dpp/access-control#GeographicContext
:GeographicContext rdf:type owl:Class ;
                   rdfs:subClassOf :AccessContext ;
                   <http://www.w3.org/2004/02/skos/core#definition> "A jurisdictional constraint on where access may be exercised."@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Geographic Context"@en .


###  http://w3id.org/dpp/access-control#HumanPrincipal
:HumanPrincipal rdf:type owl:Class ;
                rdfs:subClassOf :Principal ;
                <http://www.w3.org/2004/02/skos/core#definition> "A natural person acting as a DPP data requester or owner."@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "Human Principal"@en .


###  http://w3id.org/dpp/access-control#OrganisationPrincipal
:OrganisationPrincipal rdf:type owl:Class ;
                       rdfs:subClassOf :Principal ;
                       <http://www.w3.org/2004/02/skos/core#definition> "A legal entity or organisation acting as a DPP stakeholder."@en ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Organisation Principal"@en .


###  http://w3id.org/dpp/access-control#Principal
:Principal rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Party> ,
                           <http://www.w3.org/ns/prov#Agent> ;
           <http://www.w3.org/2004/02/skos/core#definition> """Any entity — human, organisation, or automated system — that
         may request access to DPP resources."""@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Principal"@en .


###  http://w3id.org/dpp/access-control#PurposeContext
:PurposeContext rdf:type owl:Class ;
                rdfs:subClassOf :AccessContext ,
                                <https://w3id.org/dpv#Purpose> ;
                <http://www.w3.org/2004/02/skos/core#definition> """The declared purpose for which a Principal requests access,
         per GDPR Article 5(1)(b) purpose limitation."""@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "Purpose Context"@en .


###  http://w3id.org/dpp/access-control#Role
:Role rdf:type owl:Class ;
      <http://www.w3.org/2004/02/skos/core#definition> """A named function or responsibility assigned to a Principal
         that determines which access policies apply."""@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Access Control Role"@en .


###  http://w3id.org/dpp/access-control#SystemPrincipal
:SystemPrincipal rdf:type owl:Class ;
                 rdfs:subClassOf :Principal ;
                 <http://www.w3.org/2004/02/skos/core#definition> """An automated agent or software system acting as a DPP data
         consumer or producer."""@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "System Principal"@en .


###  http://w3id.org/dpp/access-control#TemporalContext
:TemporalContext rdf:type owl:Class ;
                 rdfs:subClassOf :AccessContext ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A time window within which access is permitted."@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Temporal Context"@en .


###  http://w3id.org/dpp/access-control#TrustContext
:TrustContext rdf:type owl:Class ;
              rdfs:subClassOf :AccessContext ;
              <http://www.w3.org/2004/02/skos/core#definition> """The assurance level of the authentication mechanism used
         by the requesting Principal."""@en ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Trust Context"@en .


