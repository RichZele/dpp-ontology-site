  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "resource sensitivity"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Allowed values: PUBLIC, RESTRICTED, CONFIDENTIAL,\n         STRICTLY_CONFIDENTIAL."
  } ]
