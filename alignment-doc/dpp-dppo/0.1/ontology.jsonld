    "@value" : "Rahel Kebede"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "DPP-DPPO.xlsx"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "The alignment ontology between DPP and DPPO"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "http://w3id.org/dpp/alignment/dpp-dppo/"
  } ]
}, {
  "@id" : "http://www.w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0001",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "DPP_DPPO_0001"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://www.w3id.org/dpp/alignment/dpp-dppo/"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/sssom/Mapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "DPP is stricter: product≠material; DPPO keeps them possibly overlapping. Subclass mapping preserves DPPO’s sector-agnostic stance without breaking DPP's disjointness."
  } ],
  "https://w3id.org/sssom/mapping_justificatio" : [ {
    "@id" : "https://w3id.org/semapv/vocab/ManualMappingCuration"
  } ],
  "https://w3id.org/sssom/object_label" : [ {
    "@value" : "Product"
  } ],
  "https://w3id.org/sssom/object_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "https://w3id.org/sssom/subject_label" : [ {
    "@value" : "Product"
  } ],
  "https://w3id.org/sssom/subject_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "http://www.w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0002",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "DPP_DPPO_0002"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://www.w3id.org/dpp/alignment/dpp-dppo/"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/sssom/Mapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Both represent part-whole relationships. Structural correspondence: both as subclasses of Product with part-of links. Modular alignment allows complex product breakdowns in DPP (e.g., building elements into sub-components) to map into DPPO’s composition pattern."
  } ],
  "https://w3id.org/sssom/mapping_justificatio" : [ {
    "@id" : "https://w3id.org/semapv/vocab/ManualMappingCuration"
  } ],
  "https://w3id.org/sssom/object_label" : [ {
    "@value" : "Component"
  } ],
  "https://w3id.org/sssom/object_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "https://w3id.org/sssom/subject_label" : [ {
    "@value" : "Component"
  } ],
  "https://w3id.org/sssom/subject_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "http://www.w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0003",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "DPP_DPPO_0003"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://www.w3id.org/dpp/alignment/dpp-dppo/"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/sssom/Mapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Semantically equivalent: both capture the matter constituting products/parts. Subclass mapping (dppo:Material ⊑ dppo:Product) reflects DPPO’s flexibility; DPP’s modular placement preserves structure. Alignment preserves CE relevance (resource loops, recyclability)."
  } ],
  "https://w3id.org/sssom/mapping_justificatio" : [ {
    "@id" : "https://w3id.org/semapv/vocab/ManualMappingCuration"
  } ],
  "https://w3id.org/sssom/object_label" : [ {
    "@value" : "Material"
  } ],
  "https://w3id.org/sssom/object_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "https://w3id.org/sssom/subject_label" : [ {
    "@value" : "Material"
  } ],
  "https://w3id.org/sssom/subject_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "http://www.w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0004",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "DPP_DPPO_0004"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://www.w3id.org/dpp/alignment/dpp-dppo/"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/sssom/Mapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Both model partonomy as first-class nodes; quantitative details remain attached to the reified link."
  } ],
  "https://w3id.org/sssom/mapping_justificatio" : [ {
    "@id" : "https://w3id.org/semapv/vocab/ManualMappingCuration"
  } ],
  "https://w3id.org/sssom/object_label" : [ {
    "@value" : "CompositionInformation"
  } ],
  "https://w3id.org/sssom/object_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "https://w3id.org/sssom/subject_label" : [ {
    "@value" : "MaterialComposition"
  } ],
  "https://w3id.org/sssom/subject_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "http://www.w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0005",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "DPP_DPPO_0005"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://www.w3id.org/dpp/alignment/dpp-dppo/"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/sssom/Mapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "For product-level roles, keep DPP’s AgentRole on dpp:Product; additionally mint DPPO responsibleActor on each DPPInformation item to meet DPPO’s auditability."
  } ],
  "https://w3id.org/sssom/mapping_justificatio" : [ {
    "@id" : "https://w3id.org/semapv/vocab/ManualMappingCuration"
  } ],
  "https://w3id.org/sssom/object_label" : [ {
    "@value" : "Actor"
  } ],
  "https://w3id.org/sssom/object_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "https://w3id.org/sssom/subject_label" : [ {
    "@value" : "Agent"
  } ],
  "https://w3id.org/sssom/subject_type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
