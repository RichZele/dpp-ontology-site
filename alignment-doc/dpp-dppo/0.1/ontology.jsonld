  } ]
}, {
  "@id" : "http://www.w3id.org/dpp/alignment/dpp-dppo/",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Eva Blomqvist"
  }, {
    "@value" : "Huanyu Li"
  }, {
    "@value" : "Rahel Kebede"
  } ],
