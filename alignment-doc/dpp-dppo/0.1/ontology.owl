    <!-- http://purl.org/dc/elements/1.1/identifier -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/identifier"/>
    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/source -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- https://w3id.org/sssom/mapping_justificatio -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/sssom/mapping_justificatio"/>
    


    <!-- https://w3id.org/sssom/object_label -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/sssom/object_label"/>
    


    <!-- https://w3id.org/sssom/object_type -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/sssom/object_type"/>
    


    <!-- https://w3id.org/sssom/subject_label -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/sssom/subject_label"/>
    


    <!-- https://w3id.org/sssom/subject_type -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/sssom/subject_type"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://w3id.org/dpp#hasComponent -->


    <owl:ObjectProperty rdf:about="http://w3id.org/dpp#hasComponent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/dppo/ontology/dpp-odp/hasPart"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/dppo/ontology/dpp-odp/hasPart -->


    <owl:ObjectProperty rdf:about="https://w3id.org/dppo/ontology/dpp-odp/hasPart"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://w3id.org/dpp#Agent -->


    <owl:Class rdf:about="http://w3id.org/dpp#Agent">
        <owl:equivalentClass rdf:resource="https://w3id.org/dppo/ontology/dpp-prov/Actor"/>
    </owl:Class>
    


    <!-- http://w3id.org/dpp#Component -->


    <owl:Class rdf:about="http://w3id.org/dpp#Component">
        <owl:equivalentClass rdf:resource="https://w3id.org/dppo/ontology/dpp-core/Component"/>
    </owl:Class>
    


    <!-- http://w3id.org/dpp#Material -->


    <owl:Class rdf:about="http://w3id.org/dpp#Material">
        <rdfs:subClassOf rdf:resource="https://w3id.org/dppo/ontology/dpp-core/Material"/>
    </owl:Class>
    


    <!-- http://w3id.org/dpp#MaterialComposition -->


    <owl:Class rdf:about="http://w3id.org/dpp#MaterialComposition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/dppo/ontology/dpp-info/CompositionInformation"/>
    </owl:Class>
    


    <!-- http://w3id.org/dpp#Product -->


    <owl:Class rdf:about="http://w3id.org/dpp#Product">
        <rdfs:subClassOf rdf:resource="https://w3id.org/dppo/ontology/dpp-odp/Product"/>
    </owl:Class>
    


    <!-- https://w3id.org/dppo/ontology/dpp-core/Component -->


    <owl:Class rdf:about="https://w3id.org/dppo/ontology/dpp-core/Component"/>
    


    <!-- https://w3id.org/dppo/ontology/dpp-core/Material -->


    <owl:Class rdf:about="https://w3id.org/dppo/ontology/dpp-core/Material"/>
    


    <!-- https://w3id.org/dppo/ontology/dpp-info/CompositionInformation -->


    <owl:Class rdf:about="https://w3id.org/dppo/ontology/dpp-info/CompositionInformation"/>
    


    <!-- https://w3id.org/dppo/ontology/dpp-odp/Product -->


    <owl:Class rdf:about="https://w3id.org/dppo/ontology/dpp-odp/Product"/>
    


    <!-- https://w3id.org/dppo/ontology/dpp-prov/Actor -->


    <owl:Class rdf:about="https://w3id.org/dppo/ontology/dpp-prov/Actor"/>
    


    <!-- https://w3id.org/sssom/Mapping -->


    <owl:Class rdf:about="https://w3id.org/sssom/Mapping"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0001 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0001">
        <rdf:type rdf:resource="https://w3id.org/sssom/Mapping"/>
        <dc:identifier>DPP_DPPO_0001</dc:identifier>
        <terms:source>https://w3id.org/dpp/alignment/dpp-dppo/</terms:source>
        <rdfs:comment>DPP is stricter: product≠material; DPPO keeps them possibly overlapping. Subclass mapping preserves DPPO’s sector-agnostic stance without breaking DPP&apos;s disjointness.</rdfs:comment>
        <sssom:mapping_justificatio rdf:resource="https://w3id.org/semapv/vocab/ManualMappingCuration"/>
        <sssom:object_label>Product</sssom:object_label>
        <sssom:object_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
        <sssom:subject_label>Product</sssom:subject_label>
        <sssom:subject_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0002 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0002">
        <rdf:type rdf:resource="https://w3id.org/sssom/Mapping"/>
        <dc:identifier>DPP_DPPO_0002</dc:identifier>
        <terms:source>https://w3id.org/dpp/alignment/dpp-dppo/</terms:source>
        <rdfs:comment>Both represent part-whole relationships. Structural correspondence: both as subclasses of Product with part-of links. Modular alignment allows complex product breakdowns in DPP (e.g., building elements into sub-components) to map into DPPO’s composition pattern.</rdfs:comment>
        <sssom:mapping_justificatio rdf:resource="https://w3id.org/semapv/vocab/ManualMappingCuration"/>
        <sssom:object_label>Component</sssom:object_label>
        <sssom:object_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
        <sssom:subject_label>Component</sssom:subject_label>
        <sssom:subject_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0003 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0003">
        <rdf:type rdf:resource="https://w3id.org/sssom/Mapping"/>
        <dc:identifier>DPP_DPPO_0003</dc:identifier>
        <terms:source>https://w3id.org/dpp/alignment/dpp-dppo/</terms:source>
        <rdfs:comment>Semantically equivalent: both capture the matter constituting products/parts. Subclass mapping (dppo:Material ⊑ dppo:Product) reflects DPPO’s flexibility; DPP’s modular placement preserves structure. Alignment preserves CE relevance (resource loops, recyclability).</rdfs:comment>
        <sssom:mapping_justificatio rdf:resource="https://w3id.org/semapv/vocab/ManualMappingCuration"/>
        <sssom:object_label>Material</sssom:object_label>
        <sssom:object_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
        <sssom:subject_label>Material</sssom:subject_label>
        <sssom:subject_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0004 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0004">
        <rdf:type rdf:resource="https://w3id.org/sssom/Mapping"/>
        <dc:identifier>DPP_DPPO_0004</dc:identifier>
        <terms:source>https://w3id.org/dpp/alignment/dpp-dppo/</terms:source>
        <rdfs:comment>Both model partonomy as first-class nodes; quantitative details remain attached to the reified link.</rdfs:comment>
        <sssom:mapping_justificatio rdf:resource="https://w3id.org/semapv/vocab/ManualMappingCuration"/>
        <sssom:object_label>CompositionInformation</sssom:object_label>
        <sssom:object_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
        <sssom:subject_label>MaterialComposition</sssom:subject_label>
        <sssom:subject_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0005 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0005">
        <rdf:type rdf:resource="https://w3id.org/sssom/Mapping"/>
        <dc:identifier>DPP_DPPO_0005</dc:identifier>
        <terms:source>https://w3id.org/dpp/alignment/dpp-dppo/</terms:source>
        <rdfs:comment>For product-level roles, keep DPP’s AgentRole on dpp:Product; additionally mint DPPO responsibleActor on each DPPInformation item to meet DPPO’s auditability.</rdfs:comment>
        <sssom:mapping_justificatio rdf:resource="https://w3id.org/semapv/vocab/ManualMappingCuration"/>
        <sssom:object_label>Actor</sssom:object_label>
        <sssom:object_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
        <sssom:subject_label>Agent</sssom:subject_label>
        <sssom:subject_type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0006 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0006">
        <rdf:type rdf:resource="https://w3id.org/sssom/Mapping"/>
        <dc:identifier>DPP_DPPO_0006</dc:identifier>
        <terms:source>https://w3id.org/dpp/alignment/dpp-dppo/</terms:source>
        <rdfs:comment>DPP expresses product partonomy directly through dpp:hasComponent, while DPPO uses the generic dpp-odp:hasPart. dpp:hasComponent is aligned as a subproperty of dppo:hasPart.</rdfs:comment>
        <sssom:mapping_justificatio rdf:resource="https://w3id.org/semapv/vocab/ManualMappingCuration"/>
        <sssom:object_label>hasPart</sssom:object_label>
        <sssom:object_type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <sssom:subject_label>hasComponent</sssom:subject_label>
        <sssom:subject_type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    </owl:NamedIndividual>
</rdf:RDF>



