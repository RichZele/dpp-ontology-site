<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/dpp/alignment/dpp-dppo/"
     xml:base="https://w3id.org/dpp/alignment/dpp-dppo/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sssom="https://w3id.org/sssom/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/dpp/alignment/dpp-dppo/">
        <terms:contributor>Eva Blomqvist</terms:contributor>
        <terms:contributor>Huanyu Li</terms:contributor>
        <terms:contributor>Rahel Kebede</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-23</terms:created>
        <terms:creator>Rahel Kebede</terms:creator>
        <terms:license>https://creativecommons.org/licenses/by/4.0/</terms:license>
        <terms:source>https://github.com/RichZele/DPP-DPPO-CEON-Ontology-Alignment/blob/main/documentations/DPP-DPPO.xlsx</terms:source>
        <terms:title>The alignment ontology between DPP ontology and DPPO</terms:title>
        <rdfs:comment>This ontology represents the alignment between the Digital Product Passport (DPP) ontology and Digital Product Passport Ontology (DPPO).</rdfs:comment>
        <owl:versionInfo>0.1</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
