          "type" : "label"
        } ]
      },
      "comment" : {
        "undefined" : "DPPO uses one generic hasPart for products; CEON splits into model- and item-level shortcuts. Making both CEON properties subproperties of DPPO’s hasPart preserves DPPO queries and CEON’s extra precision. DPPO also infers partonomy from reified composition (see below)."
      },
      "labels" : {
        "IRI-based" : "DPPO_CEON_0005"
      }
    }, {
      "iri" : "https://w3id.org/dpp/alignment/dppo-ceon/DPPO_CEON_0004",
