      "comment" : {
        "undefined" : "DPPO uses Substance for basic chemical entities (elements or compounds) that might appear in a product’s composition or as regulated substances. CEON explicitly defines ChemicalSubstance and ChemicalElement classes. This can be seen as a specialization of DPPO's Substance class."
      },
      "labels" : {
        "IRI-based" : "DPPO_CEON_0003"
      }
    }, {
      "iri" : "https://w3id.org/dpp/alignment/dppo-ceon/DPPO_CEON_0002",
      "baseIri" : "https://w3id.org/dpp/alignment/dppo-ceon",
      "annotations" : {
